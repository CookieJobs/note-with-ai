version: '3.9'
services:
  server:
    build: .
    ports:
      - "3001:3001"
    volumes:
      - .:/app
    environment:
      - PORT=3001
      - MONGODB_URI=mongodb://mongo:27017/note-with-ai
      - DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}
    depends_on:
      - mongo

  mongo:
    image: mongo:6
    ports:
      - "27017:27017"
    volumes:
      - mongo-data:/data/db

volumes:
  mongo-data: