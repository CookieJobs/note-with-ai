# 数据库配置
MONGODB_URI=mongodb://localhost:27017/noteWithAI

# 服务器配置
PORT=3001
NODE_ENV=development

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# DeepSeek API 配置（可选，如果使用 DeepSeek）
DEEPSEEK_API_KEY=your-deepseek-api-key

# Embedding Provider 配置
DASHSCOPE_API_KEY=your-dashscope-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Redis 配置（可选，用于向量缓存）
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# 向量化配置
EMBEDDING_PROVIDER=openrouter
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
EMBEDDING_DIMENSION=2048
EMBEDDING_MODALITY=text
EMBEDDING_QUERY_INPUT_TYPE=search_query
EMBEDDING_DOCUMENT_INPUT_TYPE=search_document
SIMILARITY_THRESHOLD=0.7
MAX_RELATED_NOTES=3

# Embedding定时任务配置
EMBEDDING_TEST_MODE=true

# CORS 允许的来源（逗号分隔，生产环境必填）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# 日志配置
LOG_LEVEL=info
