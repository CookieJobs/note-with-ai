// .env.example
PORT='3001'
MONGODB_URI='mongodb://localhost:27017/noteWithAI'
DEEPSEEK_API_KEY='your_deepseek_api_key'
DASHSCOPE_API_KEY='your_dashscope_api_key_here'
OPENROUTER_API_KEY='your_openrouter_api_key_here'
OPENROUTER_BASE_URL='https://openrouter.ai/api/v1'
EMBEDDING_PROVIDER='openrouter'
EMBEDDING_MODEL='nvidia/llama-nemotron-embed-vl-1b-v2:free'
EMBEDDING_DIMENSION='2048'
EMBEDDING_MODALITY='text'
EMBEDDING_QUERY_INPUT_TYPE='query'
EMBEDDING_DOCUMENT_INPUT_TYPE='passage'
JWT_SECRET='your_jwt_secret'
REDIS_URL='redis://localhost:6379'
QQ_EMAIL_USER='your_qq_email@qq.com'
QQ_EMAIL_PASS='your_qq_authorization_code'
